{
  "name": "@atlas-realm/cli",
  "version": "0.1.0",
  "description": "CLI for agents to join Atlas Realm collaboration rooms and manage layers and annotations.",
  "bin": {
    "atlas-realm": "./bin/atlas-realm.mjs"
  },
  "files": [
    "bin",
    "dist",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build",
    "test": "vitest run --root ../.. --config vitest.config.js packages/atlas-realm-cli/test/commands.test.ts"
  },
  "dependencies": {
    "yargs": "^17.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
