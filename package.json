{
  "name": "atlas-realm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "pnpm build && wrangler dev",
    "atlas:realm": "pnpm --filter @atlas-realm/cli build >/dev/null && node packages/atlas-realm-cli/bin/atlas-realm.mjs",
    "screenshots:fixture": "node scripts/update-screenshot-fixture-data.mjs && oxfmt --write src/screenshot-fixture-data.ts",
    "screenshots": "node scripts/generate-screenshots.mjs",
    "generate:style": "node scripts/styles/styles.mjs && cp standard.json public/orm/style/standard.json",
    "verify:style-bitexact": "cp scripts/styles/styles.mjs /tmp/orm-styles.split.mjs && cp /tmp/style-refactor-backup/styles.mjs.orig scripts/styles/styles.mjs && node scripts/styles/styles.mjs >/dev/null && cp standard.json /tmp/orm-standard.before.json && cp /tmp/orm-styles.split.mjs scripts/styles/styles.mjs && node scripts/styles/styles.mjs >/dev/null && cmp -s standard.json /tmp/orm-standard.before.json",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.js",
    "test:worker": "vitest run --config vitest.worker.config.js",
    "test:all": "pnpm test && pnpm test:worker",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "lucide": "^1.16.0",
    "maplibre-contour": "^0.0.5",
    "maplibre-gl": "^5.18.0",
    "partyserver": "^0.5.5",
    "partysocket": "^1.1.18",
    "pbf": "^4.0.1",
    "pmtiles": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20260524.1",
    "@types/geojson": "^7946.0.16",
    "agent-browser": "^0.27.1",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^7.1.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.73.0",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@10.24.0"
}
